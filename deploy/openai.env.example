# OpenAI key for the analysis service (LLM provider + AI improvement plan).
#
# Setup (one time):
#   1. Copy this file to  deploy/openai.env   (that name is gitignored)
#   2. Paste your key after the = (no quotes)
#   3. docker compose -f deploy/docker-compose.yml up -d analysis
#
# Leave the key empty to use the deterministic rule engine (no OpenAI).
Ai__OpenAi__ApiKey=
