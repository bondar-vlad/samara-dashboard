{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/ChildRights.slnx"],
      "problemMatcher": "$msCompile",
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "test",
      "command": "dotnet",
      "type": "process",
      "args": ["test", "${workspaceFolder}/ChildRights.slnx"],
      "problemMatcher": "$msCompile",
      "group": { "kind": "test", "isDefault": true }
    },
    {
      "label": "compose-up",
      "command": "docker",
      "type": "process",
      "args": ["compose", "-f", "${workspaceFolder}/deploy/docker-compose.yml", "up", "--build"],
      "problemMatcher": []
    }
  ]
}
